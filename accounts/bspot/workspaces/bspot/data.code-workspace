{
	"folders": [
		{
			"name": "data_platform",
			"path": "../../../../../data_platform"
		},
		{
			"name": "gpn-dbt-warehouse",
			"path": "../../../../../dbt/gpn-dbt-warehouse"
		},
		{
			"name": "gpn-marts-base",
			"path": "../../../../../dbt/gpn-marts-base"
		},
		{
			"name": "Github-Experimenting",
			"path": "../../../../../Github-Experimenting"
		},
		{
			"name": "hex-bspot",
			"path": "../../../../../hex-bspot"
		},
		{
			"name": "dotfiles",
			"path": "../.."
		}
	],
	"settings": {
		"python.defaultInterpreterPath": "${userHome}/.venvs/gpn-dbt-warehouse/bin/python",

		"[sql]": {
			"editor.defaultFormatter": "sqlfluff.vscode-sqlfluff",
			"editor.formatOnSave": false,
			"editor.tabSize": 4
		},
		"[jinja-sql]": {
			"editor.defaultFormatter": "sqlfluff.vscode-sqlfluff",
			"editor.formatOnSave": false,
			"editor.tabSize": 4
		},
		"[yaml]": {
			"editor.tabSize": 2
		},
		"[python]": {
			"editor.tabSize": 4,
			"editor.formatOnSave": true
		},

		"sqlfluff.executablePath": "/Users/mlacorte/.venvs/gpn-marts-base/bin/sqlfluff",
		"sqlfluff.linter.run": "onSave",
		"sqlfluff.dialect": "redshift",

		"files.exclude": {
			"**/.DS_Store": true
		},
		"files.associations": {
			"*.sql": "jinja-sql",
			"env": "shellscript"
		}
	},
	"extensions": {
		"recommendations": [
			"innoverio.vscode-dbt-power-user",
			"ms-python.python",
			"sqlfluff.vscode-sqlfluff",
			"redhat.vscode-yaml",
			"samuelcolvin.jinjahtml"
		]
	}
}
